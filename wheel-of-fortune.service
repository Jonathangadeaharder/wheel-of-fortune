[Unit]
Description=Wheel of Fortune - Express + React
After=network.target

[Service]
User=meganet
Group=www-data
WorkingDirectory=/home/meganet/wheel-of-fortune
Environment="PATH=/home/meganet/.fnm:/usr/local/bin:/usr/bin:/bin"
Environment="NODE_ENV=production"
Environment="PORT=3001"
ExecStart=/bin/bash -c 'eval "$(/home/meganet/.fnm/fnm env --shell bash)" && npx tsx /home/meganet/wheel-of-fortune/server.ts'
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
