{
  "name": "wheel-of-fortune",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "clsx": "^2.1.0",
    "express": "^4.19.2",
    "lucide-react": "^0.263.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "vite": "^5.4.10"
  },
  "scripts": {
    "prestart": "lsof -ti:3001 | xargs -r kill -9 2>/dev/null || true; lsof -ti:5173 | xargs -r kill -9 2>/dev/null || true",
    "start": "concurrently \"node server.js\" \"vite\" --names \"backend,frontend\" --prefix-colors \"cyan,magenta\"",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "frontend": "vite",
    "build-and-serve": "npm run build && npm run server"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
